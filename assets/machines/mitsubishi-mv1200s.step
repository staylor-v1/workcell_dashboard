ENDSEC;
DATA;
#1=APPLICATION_CONTEXT('mechanical design');
#2=PRODUCT_CONTEXT('machine asset',#1,'manufacturing equipment');
#3=PRODUCT('MACHINE_MITSUBISHI-MV1200S','Mitsubishi MV1200S','Wire EDM; footprint 2.025m x 2.76m x 2.015m. Source: https://www.mitsubishielectric-edm.eu/products-solutions/wire-erosion/mv-s-series/ CAD source searched: Mitsubishi EDM downloads include layout drawing, not redistributable 3D CAD (https://www.mitsubishielectric-edm.eu/service/downloads/). Asset note: Deterministic STEP proxy scaled to Mitsubishi documented installation footprint; public download search found layout drawings but no redistributable 3D CAD.',(#2));
#4=PRODUCT_DEFINITION_FORMATION_WITH_SPECIFIED_SOURCE('1','deterministic proxy for render/layout use',#3,.MADE.);
#5=PRODUCT_DEFINITION_CONTEXT('part definition',#1,'design');
#6=PRODUCT_DEFINITION('design','Mitsubishi MV1200S deterministic render proxy',#4,#5);
#7=PRODUCT_DEFINITION_SHAPE('shape','Axis-aligned equipment envelope used by render scene generator',#6);
#8=PROPERTY_DEFINITION('asset_id','mitsubishi-mv1200s',#6);
#9=PROPERTY_DEFINITION('width_m','2.025',#6);
#10=PROPERTY_DEFINITION('depth_m','2.76',#6);
#11=PROPERTY_DEFINITION('height_m','2.015',#6);
#12=PROPERTY_DEFINITION('render_geometry','box_with_control_panel_cable_tray_and_status_light',#6);
#15=PROPERTY_DEFINITION('dimension_source','Mitsubishi MV-S series specs: https://www.mitsubishielectric-edm.eu/products-solutions/wire-erosion/mv-s-series/',#6);
#16=PROPERTY_DEFINITION('cad_source','Mitsubishi EDM downloads include layout drawing, not redistributable 3D CAD: https://www.mitsubishielectric-edm.eu/service/downloads/',#6);
#17=PROPERTY_DEFINITION('asset_note','Deterministic STEP proxy scaled to Mitsubishi documented installation footprint; public download search found layout drawings but no redistributable 3D CAD.',#6);
#13=SHAPE_REPRESENTATION('machine_10_proxy_envelope',(),#14);
#14=GEOMETRIC_REPRESENTATION_CONTEXT(3);
ENDSEC;
