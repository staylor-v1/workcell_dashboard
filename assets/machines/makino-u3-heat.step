#15=PROPERTY_DEFINITION('dimension_source','Makino U3 H.E.A.T. specification sheet: https://static.machinetools.com/uploads/8129344/Makino-U3-Spec-Sheet.pdf',#6);
#16=PROPERTY_DEFINITION('cad_source','No public OEM CAD found; app proxy uses Makino machine-tool dimensions: https://static.machinetools.com/uploads/8129344/Makino-U3-Spec-Sheet.pdf',#6);
#17=PROPERTY_DEFINITION('asset_note','Deterministic STEP proxy scaled to documented Makino machine-tool dimensions because no redistributable OEM CAD model was found.',#6);
#13=SHAPE_REPRESENTATION('machine_12_proxy_envelope',(),#14);
#14=GEOMETRIC_REPRESENTATION_CONTEXT(3);
