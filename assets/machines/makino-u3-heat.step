DATA;
#1=APPLICATION_CONTEXT('mechanical design');
#2=PRODUCT_CONTEXT('machine asset',#1,'manufacturing equipment');
#3=PRODUCT('MACHINE_MAKINO-U3-HEAT','Makino U3 H.E.A.T.','Wire EDM; footprint 1.95m x 2.3m x 2.116m. Source: https://static.machinetools.com/uploads/8129344/Makino-U3-Spec-Sheet.pdf CAD source searched: No public OEM CAD found; app proxy uses Makino machine-tool dimensions (https://static.machinetools.com/uploads/8129344/Makino-U3-Spec-Sheet.pdf). Asset note: Deterministic STEP proxy scaled to documented Makino machine-tool dimensions because no redistributable OEM CAD model was found.',(#2));
#4=PRODUCT_DEFINITION_FORMATION_WITH_SPECIFIED_SOURCE('1','deterministic proxy for render/layout use',#3,.MADE.);
#5=PRODUCT_DEFINITION_CONTEXT('part definition',#1,'design');
#6=PRODUCT_DEFINITION('design','Makino U3 H.E.A.T. deterministic render proxy',#4,#5);
#7=PRODUCT_DEFINITION_SHAPE('shape','Axis-aligned equipment envelope used by render scene generator',#6);
