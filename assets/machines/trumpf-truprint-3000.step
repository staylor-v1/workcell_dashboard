ISO-10303-21;
HEADER;
FILE_DESCRIPTION(('Microfactory Studio deterministic machine CAD proxy','Bounding-box solid proxy with render metadata'),'2;1');
FILE_NAME('trumpf-truprint-3000.step','2026-06-09T00:00:00Z',('OpenAI Codex'),('Microfactory Studio'),'scripts/generate-machine-assets.mjs','Microfactory Studio','Public proxy generated because no redistributable OEM CAD was bundled');
FILE_SCHEMA(('AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF'));
ENDSEC;
DATA;
#1=APPLICATION_CONTEXT('mechanical design');
#2=PRODUCT_CONTEXT('machine asset',#1,'manufacturing equipment');
#3=PRODUCT('MACHINE_TRUMPF-TRUPRINT-3000','TRUMPF TruPrint 3000','Metal 3D printer · LPBF; footprint 3.385m x 2.07m x 1.75m. Source: https://www.trumpf.com/en_US/products/machines-systems/additive-production-systems/truprint-3000/ CAD source searched: No public OEM CAD found; app proxy uses TRUMPF documented dimensions (https://www.trumpf.com/en_US/products/machines-systems/additive-production-systems/truprint-3000/). Asset note: Deterministic STEP proxy scaled to documented dimensions including filter because no redistributable OEM CAD model was found.',(#2));
#4=PRODUCT_DEFINITION_FORMATION_WITH_SPECIFIED_SOURCE('1','deterministic proxy for render/layout use',#3,.MADE.);
#5=PRODUCT_DEFINITION_CONTEXT('part definition',#1,'design');
#6=PRODUCT_DEFINITION('design','TRUMPF TruPrint 3000 deterministic render proxy',#4,#5);
#7=PRODUCT_DEFINITION_SHAPE('shape','Axis-aligned equipment envelope used by render scene generator',#6);
#8=PROPERTY_DEFINITION('asset_id','trumpf-truprint-3000',#6);
#9=PROPERTY_DEFINITION('width_m','3.385',#6);
#10=PROPERTY_DEFINITION('depth_m','2.07',#6);
#11=PROPERTY_DEFINITION('height_m','1.75',#6);
#12=PROPERTY_DEFINITION('render_geometry','box_with_control_panel_cable_tray_and_status_light',#6);
#15=PROPERTY_DEFINITION('dimension_source','TRUMPF TruPrint 3000 specs: https://www.trumpf.com/en_US/products/machines-systems/additive-production-systems/truprint-3000/',#6);
#16=PROPERTY_DEFINITION('cad_source','No public OEM CAD found; app proxy uses TRUMPF documented dimensions: https://www.trumpf.com/en_US/products/machines-systems/additive-production-systems/truprint-3000/',#6);
#17=PROPERTY_DEFINITION('asset_note','Deterministic STEP proxy scaled to documented dimensions including filter because no redistributable OEM CAD model was found.',#6);
#13=SHAPE_REPRESENTATION('machine_7_proxy_envelope',(),#14);
#14=GEOMETRIC_REPRESENTATION_CONTEXT(3);
ENDSEC;
END-ISO-10303-21;
