#9=PROPERTY_DEFINITION('width_m','3.15',#6);
#10=PROPERTY_DEFINITION('depth_m','1.28',#6);
#11=PROPERTY_DEFINITION('height_m','2.47',#6);
#12=PROPERTY_DEFINITION('render_geometry','box_with_control_panel_cable_tray_and_status_light',#6);
#15=PROPERTY_DEFINITION('dimension_source','Nikon SLM 280 2.0 system brochure: https://nikon-slm-solutions.com/wp-content/uploads/2024/04/System-Nikon-SLM280-2-02024.pdf',#6);
#16=PROPERTY_DEFINITION('cad_source','No public OEM CAD found; app proxy uses Nikon SLM documented dimensions: https://nikon-slm-solutions.com/wp-content/uploads/2024/04/System-Nikon-SLM280-2-02024.pdf',#6);
#17=PROPERTY_DEFINITION('asset_note','Deterministic STEP proxy scaled to Nikon SLM brochure dimensions because no redistributable OEM CAD model was found.',#6);
#13=SHAPE_REPRESENTATION('machine_8_proxy_envelope',(),#14);
