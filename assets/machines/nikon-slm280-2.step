DATA;
#1=APPLICATION_CONTEXT('mechanical design');
#2=PRODUCT_CONTEXT('machine asset',#1,'manufacturing equipment');
#3=PRODUCT('MACHINE_NIKON-SLM280-2','Nikon SLM Solutions SLM 280 2.0','Metal 3D printer · LPBF; footprint 3.15m x 1.28m x 2.47m. Source: https://nikon-slm-solutions.com/wp-content/uploads/2024/04/System-Nikon-SLM280-2-02024.pdf CAD source searched: No public OEM CAD found; app proxy uses Nikon SLM documented dimensions (https://nikon-slm-solutions.com/wp-content/uploads/2024/04/System-Nikon-SLM280-2-02024.pdf). Asset note: Deterministic STEP proxy scaled to Nikon SLM brochure dimensions because no redistributable OEM CAD model was found.',(#2));
#4=PRODUCT_DEFINITION_FORMATION_WITH_SPECIFIED_SOURCE('1','deterministic proxy for render/layout use',#3,.MADE.);
#5=PRODUCT_DEFINITION_CONTEXT('part definition',#1,'design');
#6=PRODUCT_DEFINITION('design','Nikon SLM Solutions SLM 280 2.0 deterministic render proxy',#4,#5);
#7=PRODUCT_DEFINITION_SHAPE('shape','Axis-aligned equipment envelope used by render scene generator',#6);
