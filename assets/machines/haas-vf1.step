DATA;
#1=APPLICATION_CONTEXT('mechanical design');
#2=PRODUCT_CONTEXT('machine asset',#1,'manufacturing equipment');
#3=PRODUCT('MACHINE_HAAS-VF1','Haas VF-1','CNC mill · VMC; footprint 2.184m x 3.505m x 2.84m. Source: https://www.haascnc.com/machines/vertical-mills/vf-series/models/small/vf-1.html CAD source searched: Haas VF-1 3D Model ZIP (https://www.haascnc.com/machines/vertical-mills/vf-series/models/small/vf-1.html). Asset note: Deterministic STEP proxy scaled to Haas layout drawing envelope; Haas publishes a 3D Model ZIP but notes it may not match the latest production model, so it is not bundled.',(#2));
#4=PRODUCT_DEFINITION_FORMATION_WITH_SPECIFIED_SOURCE('1','deterministic proxy for render/layout use',#3,.MADE.);
#5=PRODUCT_DEFINITION_CONTEXT('part definition',#1,'design');
#6=PRODUCT_DEFINITION('design','Haas VF-1 deterministic render proxy',#4,#5);
#7=PRODUCT_DEFINITION_SHAPE('shape','Axis-aligned equipment envelope used by render scene generator',#6);
