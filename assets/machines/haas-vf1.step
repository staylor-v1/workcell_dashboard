#10=PROPERTY_DEFINITION('depth_m','3.505',#6);
#11=PROPERTY_DEFINITION('height_m','2.84',#6);
#12=PROPERTY_DEFINITION('render_geometry','box_with_control_panel_cable_tray_and_status_light',#6);
#15=PROPERTY_DEFINITION('dimension_source','Haas VF-1 specs: https://www.haascnc.com/machines/vertical-mills/vf-series/models/small/vf-1.html',#6);
#16=PROPERTY_DEFINITION('cad_source','Haas VF-1 3D Model ZIP: https://www.haascnc.com/machines/vertical-mills/vf-series/models/small/vf-1.html',#6);
#17=PROPERTY_DEFINITION('asset_note','Deterministic STEP proxy scaled to Haas layout drawing envelope; Haas publishes a 3D Model ZIP but notes it may not match the latest production model, so it is not bundled.',#6);
#13=SHAPE_REPRESENTATION('machine_14_proxy_envelope',(),#14);
